###############################################################################
# VS Code & Editor Specific
###############################################################################
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Extension-specific logs and local state
.history/
*.log
vscoqlog.txt
coq-lsp.log

###############################################################################
# Lean 4 (Lake Build System)
###############################################################################
# Lake output directory (contains build artifacts, .olean, .ilean, .c, .o files)
.lake/
# Older Lake versions used 'build' directly
build/

# Dependency source code (downloaded by Lake)
lake-packages/

# NOTE: lake-manifest.json should usually be TRACKED to ensure reproducible 
# builds. If this is a temporary experimental project, you can ignore it:
# lake-manifest.json

###############################################################################
# Coq (General & Makefile-based)
###############################################################################
# Compiled Coq files
*.vo
*.vok
*.vos
*.glob
*.aux

# Performance & Timing data
*.timing
*.timing.diff
time-of-build-after.log
time-of-build-before.log

# Proof State Caches (generated by tactics like 'lia', 'nia', etc.)
.lia.cache
.nia.cache
.nlia.cache
.nra.cache
.csdp.cache

# Build system artifacts (generated by coq_makefile)
.Makefile.d
Makefile.conf
CoqMakefile
CoqMakefile.conf
Makefile.coq
Makefile.coq.conf

###############################################################################
# Coq (Dune & OCaml-based)
###############################################################################
# Dune build directory
_build/

# OCaml/Dune environment and IDE support
.merlin
*.install
*.opam.locked

# Opam local switch (if using 'opam switch create .')
_opam/

